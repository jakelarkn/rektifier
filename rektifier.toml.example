# rektifier example config.
#
# Copy to `rektifier.toml` (gitignored by default) and edit. Point the
# binary at it via `REKTIFIER_CONFIG=/path/to/rektifier.toml`.

[server]
listen_addr        = "127.0.0.1:9000"
database_url       = "postgres://rektifier:rektifier@localhost:5432/rektifier"
# Hard per-request timeout. tower-http TimeoutLayer converts excess
# to a 408 Request Timeout — the wire response shape that DDB SDKs
# already understand. The DDB CLI client times out client-side at
# 60s; 30s leaves headroom for one server-side retry attempt.
request_timeout_ms = 30000

# Postgres pool tuning. Defaults match the pre-Obs-3 hard-coded
# values; only override if your workload needs different sizing.
[pg]
max_pool_size      = 16
wait_timeout_ms    = 5000     # fail fast under pool starvation
create_timeout_ms  = 5000     # fail fast when PG is down/unreachable
recycle_timeout_ms = 1000
# "fast" (no validation, default) | "verified" (SELECT 1 on recycle —
# ~1ms per recycle but transparent PG restart recovery) | "clean"
# (verified + DISCARD ALL, drops session state).
recycling_method   = "fast"

# Retry policy for transient PG errors (08* connection class,
# 57P0[1-5] admin_shutdown family, 40001 serialization_failure,
# 40P01 deadlock_detected) and BackendError::PoolExhausted /
# ConnectFailed. Wired by Obs-4.
[pg.retry]
max_attempts       = 3        # 1 = disable retries
initial_backoff_ms = 50
max_backoff_ms     = 1000
jitter_pct         = 25       # 0..=100

# Size caps — defaults match DDB. Raise or remove ("unlimited") to use
# rektifier as "DDB API without the artificial cliffs."
[limits]
max_item_size_bytes      = 409600    # 400 KB (DDB)
max_partition_key_bytes  = 2048      # 2 KB  (DDB)
max_sort_key_bytes       = 1024      # 1 KB  (DDB)
max_attribute_name_bytes = 65536     # 64 KB (DDB)
max_nesting_depth        = 32        # DDB

# Catalog tunables (PLAN-10 KD3 / KD4). The reconciler periodically
# rebuilds the in-memory catalog snapshot from `_rektifier_tables` and
# verifies each row against live PG.
[catalog]
reconcile_interval_ms   = 30000      # 30s (0 disables the periodic timer)
invalidate_on_local_ddl = true       # immediate reconcile after Create/Update/DeleteTable

# Tables are NOT declared in TOML as of PLAN-10 D8. Use the DDB
# `CreateTable` API to provision them at runtime — see the
# `bootstrap-tables` justfile recipe for an example.

# =============================================================================
# Authentication (PLAN-13).
# =============================================================================
#
# At least one verifier must be enabled. Pick whichever schemes
# match your environment:
#
#   [auth.sigv4]        — AWS SDK clients (drop-in compatible)
#   [auth.api_token]    — opaque Bearer tokens (rekt_pat_… / rekt_svc_…)
#   [[auth.jwt.issuer]] — Bearer JWT (gcp / azure / snowflake /
#                         databricks / neon / aws-cognito / generic)
#   [auth.permissive]   — DEV ONLY: accepts everything; loopback
#                         bind + REKTIFIER_ALLOW_UNSAFE_AUTH required
#
# Master key (32 bytes, hex / base64 / raw) for AES-GCM credential
# encryption + HMAC pepper. Required when sigv4 or api_token is
# enabled. Exactly one source.
[auth]
master_key_env  = "REKTIFIER_AUTH_MASTER_KEY"
# master_key_file = "/etc/rektifier/master.key"
# master_key_kms  = "aws-kms://arn:..."   # A2a — not yet implemented
audit_log_enabled = false  # emit per-request `auth.audit` info line

# [auth.permissive]
# enabled = true   # requires REKTIFIER_ALLOW_UNSAFE_AUTH=I_UNDERSTAND_THIS_IS_UNSAFE

# [auth.sigv4]
# enabled                  = true
# clock_skew_secs          = 900
# cache_ttl_secs           = 300
# negative_cache_ttl_secs  = 30

# [auth.api_token]
# enabled                  = true
# accept_test_tokens       = false
# cache_ttl_secs           = 300
# negative_cache_ttl_secs  = 30

# Ecosystem JWT presets — one [[auth.jwt.issuer]] per trusted IdP.
# [[auth.jwt.issuer]]
# preset            = "gcp"
# expected_audience = ["rektifier-prod"]

# [[auth.jwt.issuer]]
# preset            = "azure"
# tenant_id         = "11111111-2222-3333-4444-555555555555"
# expected_audience = ["api://rektifier"]

# [[auth.jwt.issuer]]
# preset            = "snowflake"
# account           = "ab12345.us-east-1"
# expected_audience = ["rektifier"]

# [[auth.jwt.issuer]]
# preset            = "databricks"
# workspace_url     = "https://my-shard.cloud.databricks.com"
# expected_audience = ["rektifier"]

# [[auth.jwt.issuer]]
# preset            = "neon"
# project_id        = "proj-abc"
# region            = "us-east-1"
# expected_audience = ["rektifier"]

# [[auth.jwt.issuer]]
# preset            = "aws-cognito"
# user_pool_id      = "us-east-1_abc123"
# region            = "us-east-1"
# expected_audience = ["rektifier"]

# Generic OIDC (Auth0 / Keycloak / Okta / homegrown).
# [[auth.jwt.issuer]]
# preset            = "generic"
# issuer            = "https://auth.example.com/"
# jwks_url          = "https://auth.example.com/.well-known/jwks.json"
# expected_audience = ["rektifier"]
# principal_format  = { kind = "subject", prefix = "external:" }
# # or: principal_format = { custom = "external:user:{sub}" }
