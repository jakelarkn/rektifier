export DATABASE_URL="postgres://rektifier:rektifier@localhost:5432/rektifier"

# AWS CLI / SDK config: any value works against dynamodb-local and rektifier,
# but they must be set or the SigV4 signer refuses to sign.
export AWS_ACCESS_KEY_ID="local"
export AWS_SECRET_ACCESS_KEY="local"
export AWS_DEFAULT_REGION="us-east-1"

# Default endpoint for `aws dynamodb ...` -> reference emulator.
# Override per-command with --endpoint-url to hit rektifier on :9000.
export AWS_ENDPOINT_URL="http://localhost:8000"

# rektifier config (used once the binary exists)
export REKTIFIER_LISTEN_ADDR="127.0.0.1:9000"
export REKTIFIER_LOG="info,rekt=debug"
